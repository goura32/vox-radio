# Environment configuration
# Copy to .env and fill in secrets

# Ollama configuration
OLLAMA_URL=http://ubuntu.local:11434
OLLAMA_MODEL=gemma4:e4b

# VOICEVOX configuration
VOICEVOX_URL=http://ubuntu.local:50021
VOICEVOX_SPEAKER_ID=2

# HeartFM configuration
STATION_ID=heartfm
JCBA_TOKEN_REFRESH_INTERVAL=10

# Batch / loop interval (seconds)
BATCH_INTERVAL=5

# VRM model
VRM_MODEL_PATH=./assets/model.vrm

# Output directory
OUTPUT_DIR=./outputs

# Logging level
LOG_LEVEL=INFO
