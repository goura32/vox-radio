# JCBA FM ラダリオ API 設定
JCBA_API_URL=https://radimo.smen.biz/api/v1/select_stream
HEARTFM_STATION_ID=heartfm

# Whisper (文字起こし)
WHISPER_MODEL=large-v3-turbo
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16
WHISPER_LANG=ja

# Ollama (要約・感情分析用)
OLLAMA_MODEL=gemma4:e4b
OLLAMA_URL=http://ubuntu.local:11434
SUMMARY_MAX_TOKENS=1024
EMOTION_ANALYSIS=true
USE_CONTEXT=true
CONTEXT_ROLLBACK_DEPTH=2

# VOICEVOX 音声合成
VOICEVOX_URL=http://ubuntu.local:50021
VOICEVOX_SPEAKER_ID=1
VOICEVOX_SPEED=1.0
VOICEVOX_PITCH=0.0
VOICEVOX_VOLUME=1.0
VOICEVOX_INTONATION=1.0

# VRM モデル（公式サンプルDL: https://hub.vroid.com/en/characters/7939147878897061040/models/2292219474373673889）
VRM_MODEL_PATH=./assets/vrms/avatar_sample_b.glb

# パイプライン動作
PIPELINE_LOOP=true
RADIO_BATCH_SECONDS=10
RADIO_MINUTES=0

# 録音設定
RECORD_DURATION=60
STREAM_SWITCH_OVERLAP=5
MAX_STREAMS=2

# 表情・アイドリング
EXPRESSION_INTERVAL=60.0
IDLE_BLINK_INTERVAL=4.0
IDLE_BLINK_DURATION=0.15
IDLE_BODY_SWAY_MIN=0.02
IDLE_BODY_SWAY_MAX=0.06
IDLE_BLINK_SWAY_INTERVAL=6.0
IDLE_RANDOM_BLINK_MIN=3.0
IDLE_RANDOM_BLINK_MAX=7.0
